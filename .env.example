# Social Video Studio - Environment Configuration
# Copy this file to .env and fill in your credentials

# ============================================
# Google OAuth Configuration (YouTube)
# ============================================
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project
# 3. Enable YouTube Data API v3
# 4. Create OAuth 2.0 credentials
# 5. Download client_secrets.json and place in root folder

# ============================================
# Facebook App Configuration
# ============================================
# 1. Go to https://developers.facebook.com/
# 2. Create a new app (Consumer type)
# 3. Add Facebook Login product
# 4. Add your domain to Valid OAuth Redirect URIs
FB_APP_ID=your_facebook_app_id_here
FB_APP_SECRET=your_facebook_app_secret_here

# ============================================
# Application Configuration
# ============================================
# For local development
APP_URL=http://localhost:8000

# For production (Render/Railway)
# APP_URL=https://your-app-name.onrender.com

# Session secret (generate a random string)
SESSION_SECRET=your_random_secret_key_here

# ============================================
# Optional: Production Settings
# ============================================
# DEBUG=false
# PORT=8000
